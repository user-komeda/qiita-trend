{
  "name": "qiita-trend-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "infisicalLauncher --path=/qiitaTrend/next/local -- yarn next dev",
    "build": "yarn next build",
    "start": "yarn next start",
    "lint": "eslint ./",
    "format": "prettier --write \"src/**/*.(ts|tsx)\"",
    "check": "yarn concurrently 'yarn typecheck' 'yarn lint' 'yarn format'  'yarn test' 'yarn test:e2e:ci'",
    "test": "vitest run --coverage --pool=forks",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:e2e:prepare": "infisicalLauncher --path=/qiitaTrend/next/local -- yarn playwright codegen --save-storage=playwright/.auth/qiita.json https://qiita.com",
    "test:e2e": " infisicalLauncher --path=/qiitaTrend/next/local -- yarn playwright test",
    "test:e2e:ci": "infisicalLauncher --path=/qiitaTrend/next/local -- yarn playwright test --grep-invert @local-only",
    "test:e2e:ui": "infisicalLauncher --path=/qiitaTrend/next/local -- yarn playwright test --ui",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@next/env": "^16.2.6",
    "@qiita-trend/schema": "workspace:*",
    "jsdom": "^29.1.1",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "redis": "^5.12.1",
    "remark-gfm": "^4.0.1",
    "valibot": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@fetch-mock/vitest": "0.2.18",
    "@next/eslint-plugin-next": "16.2.6",
    "@playwright/test": "^1.60.0",
    "@qiita-trend/eslint": "workspace:*",
    "@qiita-trend/tsconfig": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-testing-library": "7.16.2",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  },
  "packageManager": "yarn@4.14.1"
}
