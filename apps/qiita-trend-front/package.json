{
  "name": "qiita-trend-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "infisicalLauncher --path=/qiitaTrend/next/local --envDir=../../  -- yarn next dev",
    "build": "yarn next build",
    "start": "yarn next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.(ts|tsx)\"",
    "check": "infisicalLauncher --path=/qiitaTrend/next/local --envDir=../../ -- yarn concurrently 'yarn typecheck' 'yarn lint' 'yarn format'  'yarn test'",
    "test": "vitest run --coverage --pool=forks",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/migrate-config": "^2.0.7",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@next/env": "^16.2.4",
    "jsdom": "^29.1.1",
    "next": "16.2.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "redis": "^5.12.1",
    "remark-gfm": "^4.0.1",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@fetch-mock/vitest": "0.2.18",
    "@next/eslint-plugin-next": "16.2.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/eslint-plugin": "1.6.16",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  },
  "packageManager": "yarn@4.14.1"
}
