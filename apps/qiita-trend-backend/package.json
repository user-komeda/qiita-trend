{
  "name": "qiita-trend-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "yarn nest build -c nest-cli-prod.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "infisicalLauncher --path=/qiitaTrend/nest/local -- yarn  nest start -b swc --debug --watch",
    "start": "node dist/main",
    "lint": "eslint ./",
    "lint:fix": "eslint ./ --fix",
    "typecheck": "tsc --noEmit",
    "check": "yarn concurrently 'yarn lint' 'yarn format' 'yarn typecheck' 'yarn test'",
    "test": "infisicalLauncher --path=/qiitaTrend/nest/local -- yarn vitest run --coverage --pool=forks",
    "test:watch": "infisicalLauncher --path=/qiitaTrend/nest/local -- yarn vitest --watch",
    "test:cov": "infisicalLauncher --path=/qiitaTrend/nest/local -- yarn vitest --coverage"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/swagger": "11.4.4",
    "@qiita-trend/schema": "workspace:*",
    "axios": "^1.16.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "1.4.7",
    "redis": "5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "valibot": "1.4.1"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "7.2.3",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.24",
    "@qiita-trend/eslint": "workspace:*",
    "@qiita-trend/tsconfig": "workspace:*",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.40",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "lefthook": "2.1.9",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.8"
  },
  "packageManager": "yarn@4.14.1"
}
