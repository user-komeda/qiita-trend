{
  "name": "qiita-trend-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "yarn nest build -c nest-cli-prod.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "infisicalLauncher --path=/qiitaTrend/nest/local --envDir=../../ -- yarn  nest start -b swc --debug --watch",
    "start": "node dist/main",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "typecheck": "tsc --noEmit",
    "check": "infisicalLauncher --path=/qiitaTrend/nest/local --envDir=../../ -- yarn concurrently 'yarn lint' 'yarn format' 'yarn typecheck' 'yarn test'",
    "test": "vitest run --coverage --pool=forks",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "axios": "^1.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "1.4.7",
    "redis": "5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "7.1.33",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@eslint/migrate-config": "2.1.0",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.20",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "25.7.0",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/eslint-plugin": "1.6.17",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.6"
  },
  "packageManager": "yarn@4.14.1"
}
